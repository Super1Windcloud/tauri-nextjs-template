  "type": "module",
  "author": "SuperWindCloud",
  "homepage": "https://github.com/Super1WindCloud",
  "scripts": {
    "taze": "npx taze latest -w",
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "npm run build && next start",
    "fix": "biome check --fix  && cd src-tauri && cargo fmt",
    "test": "vitest",
    "tauri": "tauri",
    "td": "tauri dev",
    "tb": "tauri build",
    "cargo-update": "cd src-tauri && cargo upgrade",
    "clean": "npx rimraf node_modules",
    "cargo-clean": "cd src-tauri && cargo clean",
    "shadcn": "npx shadcn@latest add -a -y -o",
    "format": "prettier --write src && cd src-tauri &&  cargo fmt",
    "icon": "tauri icon  app-icon.png",
    "bump": "npm  run taze && npm  run cargo-update && npm run shadcn",
    "check": "biome check  && cd src-tauri && cargo check",
    "migrate": "biome migrate  eslint --write"
  },
  "license": "MIT",
  "prepare": "husky",
